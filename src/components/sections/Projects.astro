---
import Section from "../Section.astro";
import { Icon } from "astro-icon/components";

import { projects } from "@mycvdata";
---

<Section className={Astro.props.className} title="Personal Projects">
  <div class="grid grid-cols-1 gap-3 md:grid-cols-1 print:flex print:flex-col">
    {
      projects && projects.map(
        ({ url, description, highlights, langIcon, name, isActive, github, stack, screenshots }) => {
          return (
            <div
              data-expanded="false"
              role="contentinfo"
              class="expand-container-projects grid-span-1 group relative flex min-h-80 flex-col overflow-hidden rounded-md bg-skin-button-muted/50 p-5 shadow-sm ring-1 ring-skin-muted sm:hover:ring-2 sm:hover:ring-skin-hue sm:hover:bg-skin-button-muted transition-all duration-250 ease-in-out mb-4"
            >
              <div
                class='relative z-10 flex items-center justify-between space-x-[10px]'
              >
                <div class="flex items-center gap-2">
                  <Icon data-ccursor="lift" name={langIcon ? langIcon : 'mdi:code'} class="size-4" />
                  <div class="flex items-center gap-[6px]">
                    {isActive && url ? (
                      <a
                        class="group flex items-center gap-[6px] text-lg decoration-dotted underline-offset-[5px] hover:text-skin-hue hover:underline transition-all"
                        href={url ? url : '/'}
                        title={`View "${name}" website`}
                        target="_blank"
                      >
                        {name}
                        <span class="text-skin-hue transition ease-linear group-hover:-translate-y-0.5 group-hover:translate-x-0.5">
                          <Icon name="ri:arrow-up-line" class="rotate-45" />
                        </span>
                      </a>
                    ) : (
                      <span class="text-lg">{name}</span>
                    )}
                  </div>
                </div>

                {github && (
                  <a
                    data-ccursor="lift"
                    href={github}
                    title={`View "${name}"" in gitHub`}
                    aria-label={`View ${name} in gitHub`}
                    target="_blank"
                    rel="noopener"
                    class="opacity-75 hover:opacity-100"
                  >
                    <Icon name="mdi:github" width={24} height={24} />
                  </a>
                )}
              </div>

              {/* Screenshot carousel */}
              {screenshots && screenshots.length > 0 && (
                <div class="mt-3 mb-1" data-carousel>
                  {/* Main image area */}
                  <div class="relative rounded-md overflow-hidden aspect-video bg-black/10 group/car mb-2">
                    {screenshots.map(({ file, label, path }: { file: string; label: string; path: string }, idx: number) => (
                      <a
                        href={`/${path}/${file}`}
                        data-fancybox={`gallery-${name.replace(/[^a-z0-9]/gi, '-')}`}
                        data-caption={label}
                        data-index={String(idx)}
                        class:list={[
                          "carousel-slide absolute inset-0 transition-opacity duration-300 ease-in-out",
                          idx === 0 ? "opacity-100 z-10" : "opacity-0 z-0 pointer-events-none",
                        ]}
                      >
                        <img
                          src={`/${path}/${file}`}
                          alt={label}
                          class="w-full h-full object-contain"
                          loading={idx === 0 ? "eager" : "lazy"}
                        />
                      </a>
                    ))}

                    {/* Click-to-fullview hover hint */}
                    <div class="absolute inset-0 z-20 flex items-center justify-center opacity-0 group-hover/car:opacity-100 transition-opacity duration-200 pointer-events-none">
                      <span class="flex items-center gap-1.5 bg-black/60 text-white/90 text-xs font-medium px-3 py-1.5 rounded-full backdrop-blur-sm">
                        <Icon name="ri:fullscreen-line" class="w-3.5 h-3.5" />
                        Click to see the full view
                      </span>
                    </div>

                    {/* Caption overlay */}
                    <div class="absolute inset-x-0 bottom-0 z-20 bg-gradient-to-t from-black/70 to-transparent px-3 pt-6 pb-2 pointer-events-none">
                      <p class="text-white/90 text-xs truncate" data-carousel-caption>{screenshots[0].label}</p>
                    </div>

                    {/* Slide counter */}
                    <span class="absolute top-2 right-2 z-20 bg-black/50 text-white/80 text-[10px] font-medium px-2 py-0.5 rounded-full pointer-events-none tabular-nums" data-carousel-counter>
                      1 / {screenshots.length}
                    </span>

                    {/* Prev / Next arrows */}
                    {screenshots.length > 1 && (
                      <Fragment>
                        <button
                          type="button"
                          class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 z-20 bg-black/40 hover:bg-skin-hue text-white rounded-full p-1 opacity-100 sm:opacity-0 sm:group-hover/car:opacity-100 transition-all duration-200 backdrop-blur-sm"
                          aria-label="Previous screenshot"
                        >
                          <Icon name="ri:arrow-left-s-line" class="w-5 h-5" />
                        </button>
                        <button
                          type="button"
                          class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 z-20 bg-black/40 hover:bg-skin-hue text-white rounded-full p-1 opacity-100 sm:opacity-0 sm:group-hover/car:opacity-100 transition-all duration-200 backdrop-blur-sm"
                          aria-label="Next screenshot"
                        >
                          <Icon name="ri:arrow-right-s-line" class="w-5 h-5" />
                        </button>
                      </Fragment>
                    )}
                  </div>

                  {/* Thumbnail strip */}
                  {screenshots.length > 1 && (
                    <div
                      class="flex gap-1.5 mt-1.5 overflow-x-auto pb-1 scrollbar-thin scrollbar-thumb-skin-hue scrollbar-track-transparent"
                      data-carousel-thumbs
                    >
                      {screenshots.map(({ file, label, path }: { file: string; label: string; path: string }, idx: number) => (
                        <button
                          type="button"
                          data-thumb-index={String(idx)}
                          title={label}
                          class:list={[
                            "flex-shrink-0 w-16 h-11 rounded overflow-hidden ring-2 transition-all duration-200 cursor-pointer hover:opacity-100",
                            idx === 0 ? "ring-skin-hue opacity-100" : "ring-transparent opacity-50 hover:ring-skin-hue",
                          ]}
                        >
                          <img
                            src={`/${path}/${file}`}
                            alt={label}
                            class="w-full h-full object-contain"
                            loading="lazy"
                          />
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              )}

              <div class="after:from-skin-hue dark:after:to-skin-hue/0 flex relative flex-col print:!h-auto print:gap-2 after:bg-gradient-to-t after:absolute after:bottom-0 after:w-full print:after:hidden after:h-12 after:content-[''] h-48 group-data-[expanded=true]:after:hidden group-data-[expanded=true]:h-auto overflow-hidden duration-200 ease-out">
                <p data-ccursor="noPadding" class='relative z-10 py-3 text-sm text-skin-base'>
                  {description}
                </p>
                <ul class='text-sm'>
                  {highlights && highlights.map((highlight) => {
                    return <li data-ccursor class="text-wrap">{highlight}</li>;
                  })}
                </ul>
              </div>

              {highlights && (
                <button data-ccursor="lift" class=" expand-button-projects mt-2 print:hidden group/more w-fit cursor-pointer items-center justify-center gap-1.5 text-xs underline text-skin-muted transition-all flex">
                  <span class="expand-text-projects">Show more</span>
                  <Icon name="ri:arrow-down-s-line" class="w-4 h-4 group-hover/more:translate-y-0.5 duration-200 ease-out group-data-[expanded=true]:rotate-180" width={24} height={24}></Icon>
                </button>
              )}
              
              <ul class="flex print:hidden flex-wrap gap-2 mt-4" aria-label="Technologies used">
                {stack && Object.entries(stack).map(([label, icon]) => (
                  <li data-ccursor="lift" class="border-skin-hue/60 text-skin-hue print:p-0 print:bg-transparent print:text-zinc-800 flex gap-1 items-center border-solid print:border-none border rounded-md px-2 py-0.5 text-xs backdrop-blur-sm group/stack">
                    {icon &&
                      <span class="flex gap-1">
                      <Icon name={icon} width={16} height={16} /> <span class="group-hover/stack:text-skin-hue transition-all duration-200">{label}</span>
                      </span>
                    }
                  </li>
                ))}
              </ul>
            </div>
          );
        },
      )
    }
  </div>
</Section>
<script>
  import { Fancybox } from "@fancyapps/ui";
  Fancybox.bind('[data-fancybox]', { hideScrollbar: false });

  // show more/less
  const expandButton = document.querySelectorAll('.expand-button-projects');
  expandButton.forEach(button => {
    button.addEventListener('click', () => {
      const container = button.closest<HTMLElement>('.expand-container-projects')!;
      container.dataset.expanded = container.dataset.expanded === 'true' ? 'false' : 'true';
      const expandText = button.querySelector('.expand-text-projects')!;
      expandText.innerHTML = container.dataset.expanded === 'true' ? 'Show less' : 'Show more'
    });
  });

  // Screenshot carousels
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(carousel => {
    const slides = carousel.querySelectorAll<HTMLElement>('.carousel-slide');
    const thumbButtons = carousel.querySelectorAll<HTMLElement>('[data-thumb-index]');
    const captionEl = carousel.querySelector<HTMLElement>('[data-carousel-caption]');
    const counterEl = carousel.querySelector<HTMLElement>('[data-carousel-counter]');
    const prevBtn = carousel.querySelector<HTMLButtonElement>('.carousel-prev');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('.carousel-next');

    let current = 0;
    const total = slides.length;

    function goTo(index: number) {
      const prev = current;
      current = ((index % total) + total) % total;
      if (prev === current) return;

      slides[prev].classList.remove('opacity-100', 'z-10');
      slides[prev].classList.add('opacity-0', 'z-0', 'pointer-events-none');
      slides[current].classList.remove('opacity-0', 'z-0', 'pointer-events-none');
      slides[current].classList.add('opacity-100', 'z-10');

      thumbButtons[prev]?.classList.remove('ring-skin-hue', 'opacity-100');
      thumbButtons[prev]?.classList.add('ring-transparent', 'opacity-50');
      thumbButtons[current]?.classList.remove('ring-transparent', 'opacity-50');
      thumbButtons[current]?.classList.add('ring-skin-hue', 'opacity-100');

      if (captionEl) captionEl.textContent = slides[current].dataset.caption ?? '';
      if (counterEl) counterEl.textContent = `${current + 1} / ${total}`;

      thumbButtons[current]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    prevBtn?.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); goTo(current - 1); });
    nextBtn?.addEventListener('click', e => { e.preventDefault(); e.stopPropagation(); goTo(current + 1); });
    thumbButtons.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));
  });
</script>

<style>
  ul {
    @apply ml-4 list-disc space-y-1;
    li {
      @apply text-skin-muted marker:text-skin-hue;
    }
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.6rem;
  }

  footer span {
    border-radius: 6px;
    background: #eee;
    color: #444;
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
  }
</style>
